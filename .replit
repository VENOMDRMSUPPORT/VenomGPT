modules = ["nodejs-24"]

# Register all artifacts
[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/workspace-ide"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start services"

[[workflows.workflow]]
name = "Start services"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

# Note: Individual artifacts will start their own services
# - api-server will start on port 3001
# - workspace-ide will start on port 5173
# - mockup-sandbox will start on port 8081

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
# API configuration (non-sensitive values only)
ZAI_BASE_URL = "https://api.z.ai/api/coding/paas/v4/"

# Server ports
API_PORT = "3001"
IDE_PORT = "5173"
SANDBOX_PORT = "8081"

# Base paths
BASE_PATH = "/"

# Note: ZAI_API_KEY should be set as a Replit Secret, not here
